<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>导出预览 - 值班打卡系统</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", "Helvetica Neue", Arial, sans-serif;
            background: #f5f7fa;
            color: #606266;
            padding: 20px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        h1 {
            color: #303133;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 20px;
        }

        .header-actions {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .btn {
            padding: 8px 16px;
            border: none;
            border-radius: 4px;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-block;
        }

        .btn-back:hover {
            background: #f5f7fa;
            border-color: #c0c4cc;
        }

        /* 筛选区域 */
        .filter-section {
            background: #fff;
            border-radius: 4px;
            padding: 20px;
            margin-bottom: 20px;
            border: 1px solid #dcdfe6;
            box-shadow: 0 2px 12px 0 rgba(0, 0, 0, 0.1);
        }

        .filter-row {
            display: flex;
            gap: 12px;
            margin-bottom: 12px;
            flex-wrap: wrap;
        }

        .filter-group {
            flex: 1;
            min-width: 150px;
        }

        .filter-group label {
            display: block;
            margin-bottom: 8px;
            color: #606266;
            font-size: 12px;
        }

        .filter-group input, .filter-group select {
            width: 100%;
            padding: 8px 12px;
            background: #fff;
            border: 1px solid #dcdfe6;
            border-radius: 4px;
            color: #606266;
            font-size: 12px;
        }

        .filter-group input:focus, .filter-group select:focus {
            outline: none;
            border-color: #409eff;
        }

        .btn-back {
            background: #f4f4f5;
            color: #606266;
            border: 1px solid #dcdfe6;
        }

        .btn-back:hover {
            background: #f5f7fa;
            border-color: #c0c4cc;
        }

        /* 分组切换 */
        .group-tabs {
            display: flex;
            gap: 8px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .group-tab {
            padding: 8px 16px;
            background: #f4f4f5;
            border: 1px solid #e9e9eb;
            border-radius: 3px;
            color: #909399;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 12px;
        }

        .group-tab:hover {
            background: #f5f7fa;
            color: #606266;
        }

        .group-tab.active {
            background: #ecf5ff;
            border-color: #409eff;
            color: #409eff;
        }

        .group-tab .count {
            margin-left: 6px;
            background: #f4f4f5;
            padding: 2px 6px;
            border-radius: 10px;
            font-size: 11px;
            color: #909399;
        }

        .group-tab.active .count {
            background: #409eff;
            color: #fff;
        }

        /* 预览信息 */
        .preview-info {
            background: #fff;
            border-radius: 4px;
            padding: 15px 20px;
            margin-bottom: 20px;
            border: 1px solid #dcdfe6;
            box-shadow: 0 2px 12px 0 rgba(0, 0, 0, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .preview-count {
            font-size: 13px;
            color: #606266;
        }

        .preview-count span {
            color: #409eff;
            font-weight: 600;
        }

        .preview-actions {
            display: flex;
            gap: 8px;
        }

        .btn-export-csv {
            background: #67c23a;
            color: white;
            border: none;
        }

        .btn-export-csv:hover {
            background: #85ce61;
        }

        .btn-export-json {
            background: #e6a23c;
            color: white;
            border: none;
        }

        .btn-export-json:hover {
            background: #ebb563;
        }

        .btn-export-txt {
            background: #409eff;
            color: white;
            border: none;
        }

        .btn-export-txt:hover {
            background: #66b1ff;
        }

        /* 数据表格 */
        .table-container {
            overflow-x: auto;
            background: #fff;
            border-radius: 4px;
            padding: 0;
            border: 1px solid #dcdfe6;
            box-shadow: 0 2px 12px 0 rgba(0, 0, 0, 0.1);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: #fff;
        }

        thead th {
            background: #fafafa;
            color: #606266;
            padding: 12px 10px;
            text-align: left;
            font-weight: 600;
            font-size: 12px;
            white-space: nowrap;
            border: 1px solid #ebeef5;
            border-bottom: 1px solid #dcdfe6;
        }

        thead th:first-child {
            text-align: center;
            width: 60px;
        }

        tbody tr {
            transition: all 0.2s;
        }

        tbody tr:nth-child(odd) {
            background: #fafafa;
        }

        tbody tr:nth-child(even) {
            background: #fff;
        }

        tbody tr:hover {
            background: #f5f7fa;
        }

        td {
            padding: 10px;
            color: #606266;
            font-size: 12px;
            vertical-align: middle;
            border: 1px solid #ebeef5;
        }

        td:first-child {
            text-align: center;
            color: #909399;
        }

        .date-cell {
            color: #409eff !important;
            font-family: 'Courier New', monospace;
            font-weight: 500;
        }

        .time-cell {
            color: #67c23a !important;
        }

        .group-cell {
            display: inline-block;
            padding: 3px 10px;
            background: #f0f9eb;
            border: 1px solid #e1f3d8;
            border-radius: 3px;
            color: #67c23a;
            font-size: 12px;
        }

        .no-group {
            display: inline-block;
            padding: 3px 10px;
            background: #f4f4f5;
            border: 1px solid #e9e9eb;
            border-radius: 3px;
            color: #909399;
            font-size: 12px;
        }

        .loading, .empty {
            text-align: center;
            padding: 80px 20px;
            color: #909399;
            background: #fff;
        }

        .empty-icon {
            font-size: 72px;
            margin-bottom: 20px;
            opacity: 0.5;
        }

        /* 响应式 */
        @media (max-width: 768px) {
            .page-header {
                flex-direction: column;
                gap: 15px;
            }

            .header-actions {
                flex-wrap: wrap;
                justify-content: center;
            }

            .filter-section {
                padding: 15px;
            }

            .filter-row {
                flex-direction: column;
            }

            .filter-group {
                width: 100%;
            }

            .preview-info {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }

            .preview-actions {
                flex-wrap: wrap;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="page-header">
            <h1>📥 导出预览</h1>
            <div class="header-actions">
                <a href="dashboard.html" class="btn btn-back">📊 返回看板</a>
                <a href="index.html" class="btn btn-back">← 返回主页</a>
            </div>
        </div>

        <!-- 筛选区域 -->
        <div class="filter-section">
            <div class="filter-row">
                <div class="filter-group">
                    <label>开始日期</label>
                    <input type="date" id="startDate">
                </div>
                <div class="filter-group">
                    <label>结束日期</label>
                    <input type="date" id="endDate">
                </div>
                <div class="filter-group">
                    <label>选择时段</label>
                    <select id="shiftSelect">
                        <option value="">-- 全部时段 --</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label>选择分组</label>
                    <select id="groupSelect">
                        <option value="">-- 全部分组 --</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label>按姓名搜索</label>
                    <input type="text" id="nameSearch" placeholder="输入姓名">
                </div>
            </div>
            <div style="display: flex; gap: 10px; margin-top: 15px;">
                <button onclick="loadData()" class="btn btn-back">🔄 刷新数据</button>
                <button onclick="clearFilters()" class="btn btn-back">清除筛选</button>
            </div>
        </div>

        <!-- 分组切换 -->
        <div class="group-tabs" id="groupTabs">
            <!-- 动态生成 -->
        </div>

        <!-- 预览信息 -->
        <div class="preview-info">
            <div class="preview-count">
                预览 <span id="previewCount">10</span> 条，共 <span id="totalCount">0</span> 条记录
            </div>
            <div class="preview-actions">
                <button onclick="exportData('csv')" class="btn btn-export-csv">📄 导出 CSV (Excel)</button>
                <button onclick="exportData('json')" class="btn btn-export-json">📝 导出 JSON</button>
                <button onclick="exportData('txt')" class="btn btn-export-txt">📃 导出 TXT</button>
            </div>
        </div>

        <!-- 数据表格 -->
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th style="width: 60px; text-align: center;">序号</th>
                        <th>日期</th>
                        <th>时段</th>
                        <th>姓名</th>
                        <th>分组</th>
                        <th>打卡时间</th>
                        <th>IP 地址</th>
                    </tr>
                </thead>
                <tbody id="recordsBody">
                    <tr>
                        <td colspan="7" class="loading">加载中...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        // 版本号用于强制刷新缓存
        const APP_VERSION = '20260611-001';
        console.log('📦 应用版本:', APP_VERSION);
        console.log('页面加载时间:', new Date().toISOString());
        
        let allRecords = [];
        let filteredRecords = [];

        // 确保 switchGroup 函数在全局作用域
        window.switchGroup = function(groupId) {
            console.log('=== 切换分组（全局函数）===');
            console.log('点击的参数 groupId:', groupId);
            
            const groupSelect = document.getElementById('groupSelect');
            
            if (groupId === 'all') {
                groupSelect.value = '';
                console.log('设置为全部分组，groupSelect.value:', groupSelect.value);
            } else {
                groupSelect.value = groupId;
                console.log('设置为特定分组，groupSelect.value:', groupSelect.value);
            }
            
            // 等待下一个事件循环再调用 loadData，确保 DOM 更新
            setTimeout(() => {
                console.log('准备调用 loadData()');
                window.loadData();
            }, 0);
            
            // 更新分组选项卡的 active 状态
            const tabs = document.querySelectorAll('.group-tab');
            tabs.forEach(tab => {
                const tabGroupId = tab.getAttribute('onclick')?.match(/switchGroup\('([^']+)'\)/)?.[1];
                if (groupId === 'all' && tabGroupId === 'all') {
                    tab.classList.add('active');
                } else if (groupId !== 'all' && tabGroupId === groupId) {
                    tab.classList.add('active');
                } else {
                    tab.classList.remove('active');
                }
            });
        };

        // 页面加载时初始化
        window.addEventListener('DOMContentLoaded', () => {
            // 默认日期为今天
            const now = new Date();
            const bjTimestamp = now.getTime() + (8 * 60 * 60 * 1000);
            const bjTime = new Date(bjTimestamp);
            const pad = (n) => String(n).padStart(2, '0');
            const today = `${bjTime.getUTCFullYear()}-${pad(bjTime.getUTCMonth() + 1)}-${pad(bjTime.getUTCDate())}`;
            
            // 默认开始日期为 30 天前
            const startDate = new Date(bjTimestamp - (30 * 24 * 60 * 60 * 1000));
            const startStr = `${startDate.getUTCFullYear()}-${pad(startDate.getUTCMonth() + 1)}-${pad(startDate.getUTCDate())}`;
            
            document.getElementById('endDate').value = today;
            document.getElementById('startDate').value = startStr;

            window.loadTimeSlots();
            window.loadGroups().then(() => {
                // 加载完分组后再加载数据，这样分组标签可以正确渲染
                window.loadData();
            });
        });

        // 加载时段列表
        window.loadTimeSlots = async function() {
            try {
                const response = await fetch('/api/time-slots');
                const slots = await response.json();
                
                const select = document.getElementById('shiftSelect');
                if (Array.isArray(slots)) {
                    slots.forEach(slot => {
                        const option = document.createElement('option');
                        option.value = slot.time_slot;
                        option.textContent = slot.time_slot;
                        select.appendChild(option);
                    });
                }
            } catch (error) {
                console.error('加载时段失败:', error);
            }
        }

        // 加载分组列表
        window.loadGroups = async function() {
            try {
                const response = await fetch('/api/groups');
                const groups = await response.json();
                
                const select = document.getElementById('groupSelect');
                select.innerHTML = '<option value="">全部分组</option>';
                
                if (Array.isArray(groups.data)) {
                    groups.data.forEach(group => {
                        const option = document.createElement('option');
                        option.value = group.id;
                        option.textContent = group.name;
                        select.appendChild(option);
                    });
                }
                
                return groups.data || [];
            } catch (error) {
                console.error('加载分组失败:', error);
                return [];
            }
        }
                return groups;
            } catch (error) {
                console.error('加载分组失败:', error);
                return [];
            }
        }

        // 加载数据
        window.loadData = async function() {
            const tbody = document.getElementById('recordsBody');
            tbody.innerHTML = '<tr><td colspan="6" class="loading">加载中...</td></tr>';

            const params = new URLSearchParams();
            
            const startDate = document.getElementById('startDate').value;
            const endDate = document.getElementById('endDate').value;
            const timeSlot = document.getElementById('shiftSelect').value;
            const groupId = document.getElementById('groupSelect').value;
            const name = document.getElementById('nameSearch').value.trim();

            if (startDate) params.append('start_date', startDate);
            if (endDate) params.append('end_date', endDate);
            if (timeSlot) params.append('time_slot', timeSlot);
            if (groupId) params.append('group_id', groupId);
            if (name) params.append('name', name);

            const apiUrl = `/api/records?${params.toString()}`;
            console.log('🔍 API 请求 URL:', apiUrl);
            console.log('📤 请求参数:', Object.fromEntries(params.entries()));

            try {
                const response = await fetch(apiUrl);
                const result = await response.json();
                
                // API 可能返回数组或对象（包含 results 字段）
                const records = Array.isArray(result) ? result : (result.results || result.data || []);
                
                console.log('📥 API 返回数据:', result);
                console.log('✅ 解析后的记录数:', records.length);
                
                allRecords = records;
                filteredRecords = records;

                // 更新统计
                document.getElementById('totalCount').textContent = records.length;
                document.getElementById('previewCount').textContent = Math.min(10, records.length);
                
                console.log('📊 当前选中的分组 ID:', groupId);
                console.log('📋 数据中的分组信息:', records.map(r => ({ name: r.name, group_id: r.group_id, group_name: r.group_name })));

                // 渲染分组切换（添加 try-catch 防止出错中断后续逻辑）
                try {
                    window.renderGroupTabs();
                } catch (e) {
                    console.error('renderGroupTabs 出错:', e);
                }

                if (records.length === 0) {
                    tbody.innerHTML = `
                        <tr>
                            <td colspan="7" class="empty">
                                <div class="empty-icon">📭</div>
                                <div>暂无打卡记录</div>
                            </td>
                        </tr>
                    `;
                    console.log('表格已清空：无数据');
                    return;
                }

                // 显示前 10 条预览
                const previewData = records.slice(0, 10);
                const startIndex = 1;
                const tableHTML = previewData.map((record, index) => `
                    <tr>
                        <td>${startIndex + index}</td>
                        <td class="date-cell">${record.duty_date || ''}</td>
                        <td class="time-cell">${record.duty_time || ''}</td>
                        <td>${record.name || ''}</td>
                        <td>${record.group_name ? `<span class="group-cell">${record.group_name}</span>` : '<span class="no-group">未分组</span>'}</td>
                        <td>${record.created_at ? window.formatTime(record.created_at) : ''}</td>
                        <td style="font-family: monospace; font-size: 11px;">${record.ip_address || ''}</td>
                    </tr>
                `).join('');
                
                console.log('准备渲染表格，数据条数:', previewData.length);
                console.log('tbody 元素:', tbody);
                tbody.innerHTML = tableHTML;
                console.log('表格已渲染，当前显示条数:', tbody.querySelectorAll('tr').length);
            } catch (error) {
                console.error('加载数据失败:', error);
                tbody.innerHTML = `<tr><td colspan="7" class="empty">加载失败：${error.message}</td></tr>`;
            }
        }

        // 格式化时间（转换为北京时间）
        window.formatTime = function(isoString) {
            if (!isoString) return '';
            const date = new Date(isoString);
            const pad = (n) => String(n).padStart(2, '0');
            return `${date.getUTCFullYear()}-${pad(date.getUTCMonth() + 1)}-${pad(date.getUTCDate())} ${pad(date.getUTCHours())}:${pad(date.getUTCMinutes())}`;
        }

        // 清除筛选
        window.clearFilters = function() {
            const now = new Date();
            const bjTimestamp = now.getTime() + (8 * 60 * 60 * 1000);
            const bjTime = new Date(bjTimestamp);
            const pad = (n) => String(n).padStart(2, '0');
            const today = `${bjTime.getUTCFullYear()}-${pad(bjTime.getUTCMonth() + 1)}-${pad(bjTime.getUTCDate())}`;
            
            const startDate = new Date(bjTimestamp - (30 * 24 * 60 * 60 * 1000));
            const startStr = `${startDate.getUTCFullYear()}-${pad(startDate.getUTCMonth() + 1)}-${pad(startDate.getUTCDate())}`;

            document.getElementById('startDate').value = startStr;
            document.getElementById('endDate').value = today;
            document.getElementById('shiftSelect').value = '';
            document.getElementById('groupSelect').value = '';
            document.getElementById('nameSearch').value = '';
            
            window.loadData();
        }

        // 导出数据
        window.exportData = function(format) {
            if (filteredRecords.length === 0) {
                alert('⚠️ 没有可导出的数据');
                return;
            }

            let content = '';
            let mimeType = '';
            let extension = '';

            const now = new Date();
            const bjTimestamp = now.getTime() + (8 * 60 * 60 * 1000);
            const bjTime = new Date(bjTimestamp);
            const pad = (n) => String(n).padStart(2, '0');
            const dateStr = `${bjTime.getUTCFullYear()}${pad(bjTime.getUTCMonth() + 1)}${pad(bjTime.getUTCDate())}`;
            const filename = `打卡记录_${dateStr}`;

            if (format === 'csv') {
                // CSV 格式（带 BOM，Excel 可识别中文）
                content = '\uFEFF';
                content += '日期，时段，姓名，分组，打卡时间，IP 地址\n';
                content += filteredRecords.map(r => 
                    `"${r.duty_date || ''}","${r.duty_time || ''}","${r.name || ''}","${r.group_name || ''}","${r.created_at || ''}","${r.ip_address || ''}"`
                ).join('\n');
                mimeType = 'text/csv;charset=utf-8;';
                extension = 'csv';
            } else if (format === 'json') {
                // JSON 格式
                content = JSON.stringify(filteredRecords, null, 2);
                mimeType = 'application/json';
                extension = 'json';
            } else if (format === 'txt') {
                // TXT 格式（表格对齐）
                content = '日期          时段      姓名      分组      打卡时间            IP 地址\n';
                content += '='.repeat(80) + '\n';
                content += filteredRecords.map(r => 
                    `${(r.duty_date || '').padEnd(12)} ${(r.duty_time || '').padEnd(8)} ${(r.name || '').padEnd(8)} ${(r.group_name || '').padEnd(8)} ${(r.created_at || '').padEnd(20)} ${(r.ip_address || '')}`
                ).join('\n');
                mimeType = 'text/plain;charset=utf-8;';
                extension = 'txt';
            }

            const blob = new Blob([content], { type: mimeType });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = `${filename}.${extension}`;
            link.click();
            URL.revokeObjectURL(link.href);

            alert(`✅ 已导出 ${filteredRecords.length} 条记录为 ${filename}.${extension}`);
        }

    </script>
</body>
</html>
