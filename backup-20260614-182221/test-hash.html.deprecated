<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>密码哈希测试工具</title>
  <style>
    body { font-family: Arial; padding: 20px; background: #1a1a2e; color: #fff; }
    input { padding: 8px; margin: 5px; width: 300px; }
    button { padding: 8px 20px; background: #4CAF50; color: white; border: none; cursor: pointer; }
    pre { background: #2a2a40; padding: 15px; border-radius: 5px; overflow: auto; }
  </style>
</head>
<body>
  <h1>🔐 密码哈希测试工具</h1>
  <p>用于验证密码哈希是否与数据库中存储的一致</p>
  
  <div>
    <label>密码：</label>
    <input type="text" id="password" value="4568527913q" />
  </div>
  <div>
    <label>Salt：</label>
    <input type="text" id="salt" value="monkeycode_salt_2026" />
  </div>
  <button onclick="testHash()">生成哈希</button>
  
  <h3>结果：</h3>
  <pre id="result"></pre>
  
  <h3>对比：</h3>
  <p>数据库中的哈希值：<code>d7e206570e0c629e3748f38d8424751a63c5c9e018a93abbe072519cba6e8edc</code></p>
  <pre id="compareResult"></pre>
  
  <script>
    async function hashPassword(password, salt) {
      const encoder = new TextEncoder();
      const data = encoder.encode(password + salt);
      const hashBuffer = await crypto.subtle.digest('SHA-256', data);
      const hashArray = Array.from(new Uint8Array(hashBuffer));
      return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
    }
    
    async function testHash() {
      const password = document.getElementById('password').value;
      const salt = document.getElementById('salt').value;
      
      const hash = await hashPassword(password, salt);
      document.getElementById('result').textContent = hash;
      
      const stored = 'd7e206570e0c629e3748f38d8424751a63c5c9e018a93abbe072519cba6e8edc';
      
      if (hash === stored) {
        document.getElementById('compareResult').textContent = '✅ 哈希值一致！密码正确。\n\n数据库存储：' + stored;
        document.getElementById('compareResult').style.color = '#4CAF50';
      } else {
        document.getElementById('compareResult').textContent = '❌ 哈希值不一致！\n\n生成的：' + hash + '\n数据库的：' + stored;
        document.getElementById('compareResult').style.color = '#ff6b6b';
      }
    }
  </script>
</body>
</html>
